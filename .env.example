# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Mollie OAuth Application ─────────────────────────────────────────────────
# Create your OAuth app at: https://my.mollie.com/dashboard/developers/applications
MOLLIE_CLIENT_ID=app_xxxxxxxxxxxxxxxxxxxxxx
MOLLIE_CLIENT_SECRET=your_mollie_client_secret

# Advanced access token (for creating client links - needs clients.write scope)
# Generate at: https://my.mollie.com/dashboard/developers/api-access
# Use a Test-mode token for local dev; Live-mode token for production onboarding
MOLLIE_ACCESS_TOKEN=access_xxxxxxxxxxxxxxxxxxxxxx

# API mode for merchant profiles (test | live). Defaults to test in development.
MOLLIE_API_MODE=test

# ─── CVR registry (DataCVR / datacvrapi.dk) ───────────────────────────────────
# Recommended: free API key for name autocomplete (25 lookups/day on free tier).
# Without a key, the app falls back to cvrapi.dk (CVR lookup + single name match).
# Sign up: https://datacvrapi.dk/opret-konto
# CVR_API_KEY=your_datacvr_api_key
# CVR_API_BASE_URL=https://datacvrapi.dk/api/v2

# ─── OAuth Callback ───────────────────────────────────────────────────────────
# The URL Mollie will redirect merchants to after they authorize your app
# Must match the redirect_uri registered in your Mollie OAuth application
# Local dev: http://localhost:3000/api/v1/onboarding/callback
MOLLIE_REDIRECT_URI=http://localhost:3000/api/v1/onboarding/callback

# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL of this service (used to construct redirect URIs)
# Configured for Danish merchants (country: DK, locale: da_DK, currency: DKK)
APP_BASE_URL=http://localhost:3000

# ─── Local persistence (dev) ────────────────────────────────────────────────────
# Merchants and OAuth tokens are saved here so they survive server restarts.
# MERCHANT_DATA_DIR=data
